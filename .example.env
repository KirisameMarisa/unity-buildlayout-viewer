# PostgreSQL connection string (required)
# For Docker: use "db" as the host  →  postgresql://user:password@db:5432/buildlayoutviewer
# For local dev: use "localhost"    →  postgresql://user:password@localhost:5432/buildlayoutviewer
DATABASE_URL=postgresql://user:password@db:5432/buildlayoutviewer

# Production build output directory (required for npm run build)
BUILD_OUTPUT_DIR=/path/to/output

# Upload behavior (optional — values below are defaults)
NEXT_PUBLIC_UPLOAD_TIMEOUT_MS=300000
NEXT_PUBLIC_UPLOAD_POLLING_MS=5000

# Server performance tuning (optional — value below is default)
DB_LOG_SLOW_THRESHOLD_MS=20
